#!/bin/bash
set -u

<% if p('tls.certificate') != "" && p('tls.key') != ""
     scheme = "https"
   else
     scheme = "http"
   end %>
echo "[$(date)] uploading rules to Shout!"
curl --fail -Lv -k -u "<%= p('admin.username') %>:<%= p('admin.password') %>" \
  -X POST --data-binary @/var/vcap/jobs/shout/config/shout.rules \
  <%= scheme %>://127.0.0.1:<%= p('port') %>/rules

if [[ $? != 0 ]]; then
	echo "[$(date)] failed to upload rules to Shout!; check the syntax of your rules file..."
	exit $?
fi

exit 0
